# ============================================================
# PlateRisk-NYC .gitignore
# ============================================================

# --- DATA (never commit raw data) ---
*.csv
*.xlsx
*.json
data/*.csv
data/*.xlsx

# --- NOTEBOOK CHECKPOINTS ---
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# --- PYTHON ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# --- VIRTUAL ENVIRONMENTS ---
.env
.venv
env/
venv/
ENV/

# --- OS FILES ---
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# --- IDE / EDITOR ---
.vscode/
.idea/
*.swp
*.swo

# --- JUPYTER ---
*.ipynb_checkpoints
profile_default/
ipython_config.py

# --- CREDENTIALS (never commit these) ---
*.pem
*.key
secrets.py
config.py
.env.local